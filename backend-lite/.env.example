# Core app
# ==========================================
# AUTO-EDITOR LITE (CLOUD DEPLOYMENT .ENV)
# ==========================================

# 1. Provide your Supabase / PostgreSQL connect string
# It must start with postgres:// or postgresql://
DATABASE_URL=postgres://postgres.xxxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# 2. FFMPEG Configuration
# FFMPEG is required. Render typically has FFMPEG installed. 
# If running locally, you must provide the path.
# FFMPEG_BINARY=/usr/bin/ffmpeg

# 3. Application Settings
FRONTEND_BASE_URL=http://localhost:5173
MAX_UPLOAD_MB=2000
PROCESS_TOKEN_COST=25
STARTING_TOKENS=120
FREE_DAILY_TOKENS=100

# 4. Optional Stripe Configuration for Payments
STRIPE_SECRET_KEY=sk_test_...

# 5. Optional Email Configuration (For Password Reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# 6. YouTube API settings (For Direct Upload Demo)
YOUTUBE_BACKEND_REDIRECT_URI=http://localhost:8000/auth/youtube/callback
SMTP_PASS=
SMTP_FROM=

# Limits
MAX_UPLOAD_MB=500
